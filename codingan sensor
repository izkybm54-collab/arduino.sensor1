long waktu, jarak;

void setup()
{
  pinMode(3, OUTPUT);
  pinMode(2, INPUT);
  Serial.begin(9600);
}

void loop()
{
  digitalWrite(3, LOW);
  delayMicroseconds(10);
  digitalWrite(3, HIGH);
  delayMicroseconds(10);
  digitalWrite(3, LOW);
  
  waktu=pulseIn(2, HIGH);
  jarak=0.034/2*waktu;
  Serial.print(jarak);
}
